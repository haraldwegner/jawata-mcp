<?xml version="1.0" encoding="UTF-8"?>
<!-- 22d spike: org.jawata.core compiled by PLAIN MAVEN from the existing source
     tree against Maven-Central Eclipse bundles. The jar keeps the checked-in
     OSGi MANIFEST (so it installs as the same bundle) and embeds the
     gradle-tooling lib per Bundle-ClassPath. -->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.jawata</groupId>
        <artifactId>org.jawata.build</artifactId>
        <version>3.0.1</version>
    </parent>

    <artifactId>org.jawata.core</artifactId>

    <dependencies>
        <dependency><groupId>org.eclipse.jdt</groupId><artifactId>org.eclipse.jdt.core</artifactId><version>${v.jdt.core}</version></dependency>
        <dependency><groupId>org.eclipse.jdt</groupId><artifactId>org.eclipse.jdt.launching</artifactId><version>${v.jdt.launching}</version></dependency>
        <dependency><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.resources</artifactId><version>${v.core.resources}</version></dependency>
        <dependency><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.runtime</artifactId><version>${v.core.runtime}</version></dependency>
        <dependency><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.jobs</artifactId><version>${v.core.jobs}</version></dependency>
        <dependency><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.osgi</artifactId><version>${v.osgi}</version></dependency>
        <dependency><groupId>com.fasterxml.jackson.core</groupId><artifactId>jackson-databind</artifactId><version>${v.jackson}</version></dependency>
        <dependency><groupId>org.slf4j</groupId><artifactId>slf4j-api</artifactId><version>${v.slf4j}</version></dependency>
        <dependency>
            <groupId>org.gradle</groupId><artifactId>gradle-tooling-api</artifactId><version>8.10</version>
            <scope>system</scope>
            <systemPath>${project.basedir}/../../org.jawata.core/lib/gradle-tooling-api-8.10.jar</systemPath>
        </dependency>
    </dependencies>

    <build>
        <sourceDirectory>${project.basedir}/../../org.jawata.core/src</sourceDirectory>
        <resources>
            <!-- embed the Bundle-ClassPath lib exactly as the Tycho jar does -->
            <resource>
                <directory>${project.basedir}/../../org.jawata.core</directory>
                <includes><include>lib/*.jar</include></includes>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <archive>
                        <manifestFile>${project.basedir}/../../org.jawata.core/META-INF/MANIFEST.MF</manifestFile>
                    </archive>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
