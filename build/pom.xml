<?xml version="1.0" encoding="UTF-8"?>
<!-- Sprint 22d SPIKE: plain-Maven build of jawata against Maven-Central Eclipse
     bundles + programmatic Equinox boot (the jdt.ls pattern). Branch-only —
     never part of the Tycho reactor. Version pins = the 2026-06 train as
     published on Central (verified 2026-07-12, dossier-22d.md). -->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>org.jawata</groupId>
    <artifactId>org.jawata.build</artifactId>
    <version>2.11.1</version>
    <packaging>pom</packaging>

    <modules>
        <module>core</module>
        <module>mcp</module>
        <module>boot</module>
        <module>testrunner</module>
        <module>tests-core</module>
        <module>tests-mcp</module>
        <module>dist</module>
    </modules>

    <properties>
        <maven.compiler.release>21</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- 2026-06 train on Maven Central (repo1 metadata, 2026-07-12) -->
        <v.jdt.core>3.46.0</v.jdt.core>
        <v.jdt.launching>3.24.200</v.jdt.launching>
        <v.jdt.manipulation>1.24.100</v.jdt.manipulation>
        <v.jdt.junit.core>3.14.200</v.jdt.junit.core>
        <v.jdt.junit.runtime>3.8.100</v.jdt.junit.runtime>
        <v.jdt.junit5.runtime>1.2.100</v.jdt.junit5.runtime>
        <v.ltk>3.15.200</v.ltk>
        <v.core.runtime>3.34.200</v.core.runtime>
        <v.core.resources>3.24.0</v.core.resources>
        <v.core.filesystem>1.11.400</v.core.filesystem>
        <v.core.jobs>3.15.800</v.core.jobs>
        <v.core.contenttype>3.9.800</v.core.contenttype>
        <v.core.expressions>3.9.600</v.core.expressions>
        <v.osgi>3.24.200</v.osgi>
        <v.osgi.services>3.12.300</v.osgi.services>
        <v.osgi.util>3.7.400</v.osgi.util>
        <v.text>3.14.700</v.text>
        <v.jface.text>3.31.0</v.jface.text>
        <v.equinox.common>3.20.400</v.equinox.common>
        <v.equinox.preferences>3.12.100</v.equinox.preferences>
        <v.equinox.registry>3.12.600</v.equinox.registry>
        <v.equinox.app>1.7.600</v.equinox.app>
        <v.felix.scr>2.2.18</v.felix.scr>
        <v.debug.core>3.23.300</v.debug.core>

        <!-- third-party (same pins as the Tycho target) -->
        <v.jackson>2.19.0</v.jackson>
        <v.h2>2.2.224</v.h2>
        <v.slf4j>2.0.18</v.slf4j>
    </properties>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>3.13.0</version>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-jar-plugin</artifactId>
                    <version>3.4.1</version>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-dependency-plugin</artifactId>
                    <version>3.7.1</version>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-resources-plugin</artifactId>
                    <version>3.3.1</version>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>
</project>
