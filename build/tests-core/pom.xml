<?xml version="1.0" encoding="UTF-8"?>
<!-- 22d switch: org.jawata.core.tests compiled verbatim as an OSGi FRAGMENT of
     org.jawata.core — test classes share the host's classloader, so the
     platform-bound tests run against the real booted workspace. -->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.jawata</groupId>
        <artifactId>org.jawata.build</artifactId>
        <version>2.9.0</version>
    </parent>

    <artifactId>org.jawata.core.tests</artifactId>

    <dependencies>
        <dependency><groupId>org.jawata</groupId><artifactId>org.jawata.core</artifactId><version>${project.version}</version></dependency>
        <dependency><groupId>org.junit.jupiter</groupId><artifactId>junit-jupiter</artifactId><version>5.11.4</version></dependency>
        <dependency>
            <groupId>org.gradle</groupId><artifactId>gradle-tooling-api</artifactId><version>8.10</version>
            <scope>system</scope>
            <systemPath>${project.basedir}/../../org.jawata.core/lib/gradle-tooling-api-8.10.jar</systemPath>
        </dependency>
    </dependencies>

    <build>
        <sourceDirectory>${project.basedir}/../../org.jawata.core.tests/src</sourceDirectory>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <archive><manifestFile>${project.basedir}/META-INF/MANIFEST.MF</manifestFile></archive>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
