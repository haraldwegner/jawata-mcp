<?xml version="1.0" encoding="UTF-8"?>
<!-- 22d switch: org.jawata.mcp.tests compiled verbatim as an OSGi FRAGMENT of
     org.jawata.mcp, plus SpikeTestMain (the in-framework JUnit launcher). -->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.jawata</groupId>
        <artifactId>org.jawata.build</artifactId>
        <version>2.11.1</version>
    </parent>

    <artifactId>org.jawata.mcp.tests</artifactId>

    <dependencies>
        <dependency><groupId>org.jawata</groupId><artifactId>org.jawata.mcp</artifactId><version>${project.version}</version></dependency>
        <dependency><groupId>org.jawata</groupId><artifactId>org.jawata.core</artifactId><version>${project.version}</version></dependency>
        <dependency><groupId>org.junit.jupiter</groupId><artifactId>junit-jupiter</artifactId><version>5.11.4</version></dependency>
        <dependency><groupId>org.junit.platform</groupId><artifactId>junit-platform-launcher</artifactId><version>1.11.4</version></dependency>
        <dependency><groupId>org.junit.jupiter</groupId><artifactId>junit-jupiter-engine</artifactId><version>5.11.4</version></dependency>
        <dependency>
            <groupId>org.gradle</groupId><artifactId>gradle-tooling-api</artifactId><version>8.10</version>
            <scope>system</scope>
            <systemPath>${project.basedir}/../../org.jawata.core/lib/gradle-tooling-api-8.10.jar</systemPath>
        </dependency>
    </dependencies>

    <build>
        <sourceDirectory>${project.basedir}/../../org.jawata.mcp.tests/src</sourceDirectory>
        <plugins>
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <id>add-runner</id>
                        <phase>generate-sources</phase>
                        <goals><goal>add-source</goal></goals>
                        <configuration>
                            <sources><source>${project.basedir}/src/extra/java</source></sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <archive><manifestFile>${project.basedir}/META-INF/MANIFEST.MF</manifestFile></archive>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
