<?xml version="1.0" encoding="UTF-8"?>
<!-- 22d spike: org.jawata.mcp compiled by PLAIN MAVEN from the existing source
     tree. Keeps the checked-in OSGi MANIFEST + plugin.xml (the application
     extension the app launcher resolves). -->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.jawata</groupId>
        <artifactId>org.jawata.build</artifactId>
        <version>3.0.1</version>
    </parent>

    <artifactId>org.jawata.mcp</artifactId>

    <dependencies>
        <dependency><groupId>org.jawata</groupId><artifactId>org.jawata.core</artifactId><version>${project.version}</version></dependency>
        <dependency><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.equinox.app</artifactId><version>${v.equinox.app}</version></dependency>
        <dependency><groupId>org.eclipse.jdt</groupId><artifactId>org.eclipse.jdt.core.manipulation</artifactId><version>${v.jdt.manipulation}</version></dependency>
        <!-- Sprint 23: jdt.junit.core + debug.core deps dropped with the JDT-LTK
             launch path; jdt.launching stays (runner classpath resolution) and
             brings debug.core transitively for compile. -->
        <dependency><groupId>org.eclipse.jdt</groupId><artifactId>org.eclipse.jdt.launching</artifactId><version>${v.jdt.launching}</version></dependency>
        <dependency><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.text</artifactId><version>${v.text}</version></dependency>
        <dependency><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.jface.text</artifactId><version>${v.jface.text}</version></dependency>
        <dependency><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.ltk.core.refactoring</artifactId><version>${v.ltk}</version></dependency>
        <dependency><groupId>org.jacoco</groupId><artifactId>org.jacoco.core</artifactId><version>0.8.15</version></dependency>
        <dependency><groupId>org.jacoco</groupId><artifactId>org.jacoco.report</artifactId><version>0.8.15</version></dependency>
        <dependency><groupId>com.h2database</groupId><artifactId>h2</artifactId><version>${v.h2}</version></dependency>
        <dependency><groupId>com.fasterxml.jackson.core</groupId><artifactId>jackson-databind</artifactId><version>${v.jackson}</version></dependency>
        <dependency><groupId>org.slf4j</groupId><artifactId>slf4j-api</artifactId><version>${v.slf4j}</version></dependency>
    </dependencies>

    <build>
        <sourceDirectory>${project.basedir}/../../org.jawata.mcp/src</sourceDirectory>
        <resources>
            <resource>
                <directory>${project.basedir}/../../org.jawata.mcp</directory>
                <includes><include>plugin.xml</include></includes>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <archive>
                        <manifestFile>${project.basedir}/../../org.jawata.mcp/META-INF/MANIFEST.MF</manifestFile>
                    </archive>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
