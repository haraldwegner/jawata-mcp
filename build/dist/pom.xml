<?xml version="1.0" encoding="UTF-8"?>
<!-- 22d spike: dist assembly — the plain-world replacement for the p2 product
     tree. target/dist/ = boot jar + org.eclipse.osgi (boot classpath) +
     bundles/ (the EXPLICIT Stage-1 map; no transitive surprises). The #5188
     patched compiler.batch is copied from the committed patched-bundles jar —
     the ONLY carried artifact; the official bundle is nowhere in the dist. -->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.jawata</groupId>
        <artifactId>org.jawata.build</artifactId>
        <version>3.3.1</version>
    </parent>

    <artifactId>spike-dist</artifactId>
    <packaging>pom</packaging>

    <dependencies>
        <dependency><groupId>org.jawata</groupId><artifactId>org.jawata.boot</artifactId><version>${project.version}</version></dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <executions>
                    <execution>
                        <id>boot-classpath</id>
                        <phase>package</phase>
                        <goals><goal>copy</goal></goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/dist</outputDirectory>
                            <stripVersion>false</stripVersion>
                            <artifactItems>
                                <artifactItem><groupId>org.jawata</groupId><artifactId>org.jawata.boot</artifactId><version>${project.version}</version><destFileName>jawata.jar</destFileName></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.osgi</artifactId><version>${v.osgi}</version></artifactItem>
                            </artifactItems>
                        </configuration>
                    </execution>
                    <execution>
                        <id>test-bundles</id>
                        <phase>package</phase>
                        <goals><goal>copy</goal></goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/dist/test-bundles</outputDirectory>
                            <stripVersion>false</stripVersion>
                            <artifactItems>
                                <artifactItem><groupId>org.jawata</groupId><artifactId>org.jawata.core.tests</artifactId><version>${project.version}</version></artifactItem>
                                <artifactItem><groupId>org.jawata</groupId><artifactId>org.jawata.mcp.tests</artifactId><version>${project.version}</version></artifactItem>
                                <artifactItem><groupId>org.junit.jupiter</groupId><artifactId>junit-jupiter-api</artifactId><version>5.11.4</version></artifactItem>
                                <artifactItem><groupId>org.junit.jupiter</groupId><artifactId>junit-jupiter-engine</artifactId><version>5.11.4</version></artifactItem>
                                <artifactItem><groupId>org.junit.jupiter</groupId><artifactId>junit-jupiter-params</artifactId><version>5.11.4</version></artifactItem>
                                <artifactItem><groupId>org.junit.platform</groupId><artifactId>junit-platform-commons</artifactId><version>1.11.4</version></artifactItem>
                                <artifactItem><groupId>org.junit.platform</groupId><artifactId>junit-platform-engine</artifactId><version>1.11.4</version></artifactItem>
                                <artifactItem><groupId>org.junit.platform</groupId><artifactId>junit-platform-launcher</artifactId><version>1.11.4</version></artifactItem>
                                <artifactItem><groupId>org.opentest4j</groupId><artifactId>opentest4j</artifactId><version>1.3.0</version></artifactItem>
                                <artifactItem><groupId>org.apiguardian</groupId><artifactId>apiguardian-api</artifactId><version>1.1.2</version></artifactItem>
                            </artifactItems>
                        </configuration>
                    </execution>
                    <execution>
                        <id>tools</id>
                        <phase>package</phase>
                        <goals><goal>copy</goal></goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/dist/tools</outputDirectory>
                            <stripVersion>false</stripVersion>
                            <artifactItems>
                                <!-- Sprint 23 D1: the forked-runner toolchain. The
                                     console-standalone uber jar supplies launcher +
                                     Jupiter 5.14 + Vintage engines (deliberately the
                                     latest 1.x — 6.x is JUnit 6); our runner main
                                     streams events to the parent; the TestNG engine
                                     rides along for framework=testng projects. -->
                                <artifactItem><groupId>org.junit.platform</groupId><artifactId>junit-platform-console-standalone</artifactId><version>1.14.4</version></artifactItem>
                                <artifactItem><groupId>org.jawata</groupId><artifactId>org.jawata.testrunner</artifactId><version>${project.version}</version></artifactItem>
                                <artifactItem><groupId>org.junit.support</groupId><artifactId>testng-engine</artifactId><version>1.0.6</version></artifactItem>
                                <!-- Sprint 23 D3: the coverage collector — the runtime agent
                                     rides the forked runner's -javaagent (exec parsing lives
                                     in bundles/: org.jacoco.core + report) -->
                                <artifactItem><groupId>org.jacoco</groupId><artifactId>org.jacoco.agent</artifactId><version>0.8.15</version><classifier>runtime</classifier></artifactItem>
                                <!-- Sprint 23 D5: targeted mutation testing (opt-in) -->
                                <artifactItem><groupId>org.pitest</groupId><artifactId>pitest</artifactId><version>1.25.7</version></artifactItem>
                                <artifactItem><groupId>org.pitest</groupId><artifactId>pitest-entry</artifactId><version>1.25.7</version></artifactItem>
                                <artifactItem><groupId>org.pitest</groupId><artifactId>pitest-command-line</artifactId><version>1.25.7</version></artifactItem>
                                <artifactItem><groupId>org.pitest</groupId><artifactId>pitest-junit5-plugin</artifactId><version>1.2.3</version></artifactItem>
                                <!-- the junit5 plugin needs the platform LAUNCHER at runtime;
                                     projects' jupiter aggregates don't carry it -->
                                <artifactItem><groupId>org.junit.platform</groupId><artifactId>junit-platform-launcher</artifactId><version>1.11.4</version></artifactItem>
                                <!-- PIT's XML reporter needs commons-text (+lang3) -->
                                <artifactItem><groupId>org.apache.commons</groupId><artifactId>commons-text</artifactId><version>1.12.0</version></artifactItem>
                                <artifactItem><groupId>org.apache.commons</groupId><artifactId>commons-lang3</artifactId><version>3.14.0</version></artifactItem>
                            </artifactItems>
                        </configuration>
                    </execution>
                    <execution>
                        <id>bundles</id>
                        <phase>package</phase>
                        <goals><goal>copy</goal></goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/dist/bundles</outputDirectory>
                            <stripVersion>false</stripVersion>
                            <artifactItems>
                                <!-- ours -->
                                <artifactItem><groupId>org.jawata</groupId><artifactId>org.jawata.core</artifactId><version>${project.version}</version></artifactItem>
                                <artifactItem><groupId>org.jawata</groupId><artifactId>org.jawata.mcp</artifactId><version>${project.version}</version></artifactItem>
                                <!-- JDT (compiler.batch comes from patched-bundles, below) -->
                                <artifactItem><groupId>org.eclipse.jdt</groupId><artifactId>org.eclipse.jdt.core</artifactId><version>${v.jdt.core}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.jdt</groupId><artifactId>org.eclipse.jdt.launching</artifactId><version>${v.jdt.launching}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.jdt</groupId><artifactId>org.eclipse.jdt.core.manipulation</artifactId><version>${v.jdt.manipulation}</version></artifactItem>
                                <!-- Sprint 23: jdt.junit.core + jdt.junit.runtime DROPPED — the
                                     JDT-LTK launch path they served was replaced by the forked
                                     runner (dist tools/); junit5.runtime was already dropped in
                                     22d (finding #7). debug.core stays: jdt.launching requires it. -->
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.jface</artifactId><version>3.39.100</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.equinox.simpleconfigurator</artifactId><version>1.5.700</version></artifactItem>
                                <!-- finding #8: manipulation → search.core; jface → swt.svg capability -->
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.search.core</artifactId><version>3.16.700</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.swt.svg</artifactId><version>3.133.0</version></artifactItem>
                                <!-- platform -->
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.ltk.core.refactoring</artifactId><version>${v.ltk}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.runtime</artifactId><version>${v.core.runtime}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.resources</artifactId><version>${v.core.resources}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.filesystem</artifactId><version>${v.core.filesystem}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.jobs</artifactId><version>${v.core.jobs}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.contenttype</artifactId><version>${v.core.contenttype}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.expressions</artifactId><version>${v.core.expressions}</version></artifactItem>
                                <!-- osgi.services/osgi.util facades DROPPED (boot-loop finding #6):
                                     they only re-export per-spec bundles and drag the whole
                                     org.osgi.service.* tree in; nothing of ours requires them -->
                                <artifactItem><groupId>org.eclipse.jdt</groupId><artifactId>org.eclipse.jdt.debug</artifactId><version>3.26.0</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.filebuffers</artifactId><version>3.8.600</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.swt</artifactId><version>3.134.0</version></artifactItem>
                                <!-- ONE universal dist: every platform's SWT fragment ships;
                                     Equinox's Eclipse-PlatformFilter resolves only the matching
                                     one at boot (replaces Tycho's five per-OS assets) -->
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.swt.gtk.linux.x86_64</artifactId><version>3.134.0</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.swt.gtk.linux.aarch64</artifactId><version>3.134.0</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.swt.cocoa.macosx.x86_64</artifactId><version>3.134.0</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.swt.cocoa.macosx.aarch64</artifactId><version>3.134.0</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.swt.win32.win32.x86_64</artifactId><version>3.134.0</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.equinox.simpleconfigurator.manipulator</artifactId><version>2.3.700</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.equinox.frameworkadmin</artifactId><version>2.3.600</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.equinox.frameworkadmin.equinox</artifactId><version>1.3.400</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.text</artifactId><version>${v.text}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.jface.text</artifactId><version>${v.jface.text}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.equinox.common</artifactId><version>${v.equinox.common}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.equinox.preferences</artifactId><version>${v.equinox.preferences}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.equinox.registry</artifactId><version>${v.equinox.registry}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.equinox.app</artifactId><version>${v.equinox.app}</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.debug.core</artifactId><version>${v.debug.core}</version></artifactItem>
                                <artifactItem><groupId>org.apache.felix</groupId><artifactId>org.apache.felix.scr</artifactId><version>${v.felix.scr}</version></artifactItem>
                                <!-- per-spec OSGi API bundles p2 ships individually (boot-loop finding #1) -->
                                <artifactItem><groupId>org.osgi</groupId><artifactId>org.osgi.service.component</artifactId><version>1.5.1</version></artifactItem>
                                <artifactItem><groupId>org.osgi</groupId><artifactId>org.osgi.service.prefs</artifactId><version>1.1.2</version></artifactItem>
                                <artifactItem><groupId>org.osgi</groupId><artifactId>org.osgi.util.promise</artifactId><version>1.3.0</version></artifactItem>
                                <artifactItem><groupId>org.osgi</groupId><artifactId>org.osgi.util.function</artifactId><version>1.2.0</version></artifactItem>
                                <!-- platform leaf deps (boot-loop finding #2): all OSGi-manifested on Central -->
                                <artifactItem><groupId>net.java.dev.jna</groupId><artifactId>jna</artifactId><version>5.17.0</version></artifactItem>
                                <artifactItem><groupId>net.java.dev.jna</groupId><artifactId>jna-platform</artifactId><version>5.17.0</version></artifactItem>
                                <artifactItem><groupId>com.ibm.icu</groupId><artifactId>icu4j</artifactId><version>77.1</version></artifactItem>
                                <!-- boot-loop finding #4: text requires core.commands; slf4j-api
                                     mandatorily requires the ServiceLoader extender (spifly) -->
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.commands</artifactId><version>3.12.500</version></artifactItem>
                                <artifactItem><groupId>org.apache.aries.spifly</groupId><artifactId>org.apache.aries.spifly.dynamic.bundle</artifactId><version>1.3.7</version></artifactItem>
                                <!-- boot-loop finding #5: Central spifly variant weaves via ASM;
                                     debug.core requires core.variables -->
                                <artifactItem><groupId>org.ow2.asm</groupId><artifactId>asm</artifactId><version>9.10.1</version></artifactItem>
                                <artifactItem><groupId>org.ow2.asm</groupId><artifactId>asm-commons</artifactId><version>9.10.1</version></artifactItem>
                                <artifactItem><groupId>org.ow2.asm</groupId><artifactId>asm-util</artifactId><version>9.10.1</version></artifactItem>
                                <artifactItem><groupId>org.ow2.asm</groupId><artifactId>asm-tree</artifactId><version>9.10.1</version></artifactItem>
                                <artifactItem><groupId>org.ow2.asm</groupId><artifactId>asm-analysis</artifactId><version>9.10.1</version></artifactItem>
                                <artifactItem><groupId>org.eclipse.platform</groupId><artifactId>org.eclipse.core.variables</artifactId><version>3.6.800</version></artifactItem>
                                <!-- third-party (all ship OSGi manifests) -->
                                <artifactItem><groupId>org.jacoco</groupId><artifactId>org.jacoco.core</artifactId><version>0.8.15</version></artifactItem>
                                <artifactItem><groupId>org.jacoco</groupId><artifactId>org.jacoco.report</artifactId><version>0.8.15</version></artifactItem>
                                <artifactItem><groupId>com.fasterxml.jackson.core</groupId><artifactId>jackson-databind</artifactId><version>${v.jackson}</version></artifactItem>
                                <artifactItem><groupId>com.fasterxml.jackson.core</groupId><artifactId>jackson-core</artifactId><version>${v.jackson}</version></artifactItem>
                                <artifactItem><groupId>com.fasterxml.jackson.core</groupId><artifactId>jackson-annotations</artifactId><version>${v.jackson}</version></artifactItem>
                                <artifactItem><groupId>com.h2database</groupId><artifactId>h2</artifactId><version>${v.h2}</version></artifactItem>
                                <artifactItem><groupId>org.slf4j</groupId><artifactId>slf4j-api</artifactId><version>${v.slf4j}</version></artifactItem>
                                <artifactItem><groupId>org.slf4j</groupId><artifactId>slf4j-simple</artifactId><version>${v.slf4j}</version></artifactItem>
                            </artifactItems>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <executions>
                    <execution>
                        <id>patched-compiler-batch</id>
                        <phase>package</phase>
                        <goals><goal>copy-resources</goal></goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/dist/bundles</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${project.basedir}/../../org.jawata.target/patched-bundles</directory>
                                    <includes><include>*.jar</include></includes>
                                </resource>
                                <!-- CARRY #2 (boot-loop finding #3): commonmark/org.junit/hamcrest/
                                     jsvg are not OSGi bundles on Central — carried p2-wrapped as
                                     COMMITTED jars. v2.9.2 root cause: these were copied from the
                                     gitignored Tycho product target/ tree, absent on a clean
                                     checkout; resources-plugin skips a missing dir SILENTLY, so CI
                                     shipped a dist that could not resolve. Never copy from build
                                     output of the retired build. -->
                                <resource>
                                    <directory>${project.basedir}/../../org.jawata.target/carry-bundles</directory>
                                    <includes><include>*.jar</include></includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <!-- Completeness gate (v2.9.2 lesson): every carried/patched bundle MUST
                 be present in the assembled dist, or the build FAILS here — loudly,
                 in seconds — instead of CI booting an unresolvable framework. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-enforcer-plugin</artifactId>
                <version>3.5.0</version>
                <executions>
                    <execution>
                        <id>dist-completeness</id>
                        <phase>verify</phase>
                        <goals><goal>enforce</goal></goals>
                        <configuration>
                            <rules>
                                <requireFilesExist>
                                    <files>
                                        <file>${project.build.directory}/dist/bundles/org.commonmark_0.28.0.jar</file>
                                        <file>${project.build.directory}/dist/bundles/org.commonmark.ext-gfm-tables_0.28.0.jar</file>
                                        <file>${project.build.directory}/dist/bundles/org.junit_4.13.2.v20240929-1000.jar</file>
                                        <file>${project.build.directory}/dist/bundles/org.hamcrest_3.0.0.jar</file>
                                        <file>${project.build.directory}/dist/bundles/com.github.weisj.jsvg_2.1.0.jar</file>
                                        <file>${project.build.directory}/dist/bundles/org.eclipse.jdt.core.compiler.batch_3.46.0.v20260528-0407-jawata5188.jar</file>
                                        <file>${project.build.directory}/dist/jawata.jar</file>
                                        <file>${project.build.directory}/dist/tools/junit-platform-console-standalone-1.14.4.jar</file>
                                        <file>${project.build.directory}/dist/tools/org.jawata.testrunner-${project.version}.jar</file>
                                        <file>${project.build.directory}/dist/tools/testng-engine-1.0.6.jar</file>
                                        <file>${project.build.directory}/dist/tools/org.jacoco.agent-0.8.15-runtime.jar</file>
                                        <file>${project.build.directory}/dist/tools/pitest-1.25.7.jar</file>
                                        <file>${project.build.directory}/dist/tools/pitest-entry-1.25.7.jar</file>
                                        <file>${project.build.directory}/dist/tools/pitest-command-line-1.25.7.jar</file>
                                        <file>${project.build.directory}/dist/tools/pitest-junit5-plugin-1.2.3.jar</file>
                                        <file>${project.build.directory}/dist/tools/junit-platform-launcher-1.11.4.jar</file>
                                        <file>${project.build.directory}/dist/tools/commons-text-1.12.0.jar</file>
                                        <file>${project.build.directory}/dist/tools/commons-lang3-3.14.0.jar</file>
                                        <file>${project.build.directory}/dist/bundles/org.jacoco.core-0.8.15.jar</file>
                                        <file>${project.build.directory}/dist/bundles/org.jacoco.report-0.8.15.jar</file>
                                    </files>
                                    <message>dist is INCOMPLETE — a carried/patched bundle did not reach target/dist/bundles (v2.9.2 failure class: silent copy from a missing directory)</message>
                                </requireFilesExist>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
