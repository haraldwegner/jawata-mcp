# Gradle (top-level only — unscoped `build/` would clobber the Java
# package at org.jawata.mcp/.../tools/build/ shipped in Sprint 13).
.gradle/
/build/
# Note: gradle/, gradlew, gradlew.bat are NOT ignored - they should be committed
# so others can build without installing Gradle

# IDE
.idea/
*.iml
.vscode/
.settings/
.project
.classpath
*.swp
*~

# Build outputs
*.jar
*.class
out/
target/
# Sprint 11 Phase C: embedded Bundle-ClassPath jars must be tracked
!org.jawata.core/lib/*.jar

# Working folder - session continuity docs (not tracked)
working/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temp files
*.tmp
*.bak
*.javalens.bak

# Environment
.env
.env.local

# JavaLens Eclipse workspace metadata (generated when using javalens MCP)
.javalens-workspace/

# MCP configuration (machine-specific)
.mcp.json

# npm wrapper
npm/node_modules/
npm/dist/

# Claude Code configuration (machine-specific)
.claude/
org.jawata.launcher/dependency-reduced-pom.xml
docs/REFACTORING_LESSONS_LEARNED.md

# 22c: the #5188-patched compiler.batch bundle must be tracked (Directory target
# location) — the *.jar rule silently dropped it from 8b9f8eb; sentinel caught it on CI
!org.jawata.target/patched-bundles/*.jar
!org.jawata.target/carry-bundles/*.jar

# JVM attach handshake litter (a target held at start never consumes it)
.attach_pid*

# jawata per-workspace data (quality-sweep baselines, coverage + runtime
# artifacts) — internal analysis state, never published
.jawata/
