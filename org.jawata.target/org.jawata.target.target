<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<?pde version="3.8"?>
<target name="JAWATA Target Platform (Eclipse 2026-06)" sequenceNumber="7">
    <!-- p2.base parameterizes the Eclipse download host (Sprint 21a, 2026-07-05).
         Default (canonical): https://download.eclipse.org - set in .mvn/maven.config.
         Outage fallback:     mvn ... -Dp2.base=https://ftp.fau.de/eclipse
         (official mirror, byte-identical tree). CI preflights the primary and flips the
         property automatically. p2 itself has NO metadata failover - mirrorsURL covers
         artifacts only - hence this build-level switch. -->
    <locations>
        <!-- 22c (2026-07-11): LOCAL PATCHED BUNDLE for eclipse.jdt.core#5188 — the
             official 3.46.0 compiler.batch with ONE null-guarded class swapped in
             (higher qualifier -jawata5188 makes p2 prefer it over the train's copy).
             Reproducible recipe + patched source: org.jawata.jdtpatch module.
             DELETE this location + patched-bundles/ + the jdtpatch module when a train
             with the upstream fix ships (sentinel: JreTypeResolutionTest). -->
        <location path="org.jawata.target/patched-bundles" type="Directory"/>

        <!-- Eclipse 2026-06 Release (Sprint 22c, 2026-07-11: first deliberate train choice —
             the 2024-09 pin was inherited from the initial JavaLens commit. Decision trail:
             2026-06 (4.40) hit eclipse.jdt.core#5188 (search-layer NPE in
             ProblemReporter.previewAPIUsed — unguarded even on master; reported upstream by
             us) → fell back to 2025-12 (4.38) → the SAME bug reproduced there (trigger
             machinery exists since 4.35; our 2024-09 baseline predates it) → since the
             org.jawata.jdtpatch fragment neutralizes it on any train, the newest stable
             train stands. 4.40 requires Java SE 21 (floor stays 21) and parses Java 25/26
             source (Sprint 31). Sentinel: JreTypeResolutionTest — drop the fragment when a
             train with the upstream fix ships (4.41+). -->
        <location includeAllPlatforms="false" includeConfigurePhase="true" includeMode="planner" includeSource="true" type="InstallableUnit">
            <repository location="${system_property:p2.base}/releases/2026-06"/>

            <!-- JDT Core - the heart of Java analysis -->
            <unit id="org.eclipse.jdt.core" version="0.0.0"/>
            <unit id="org.eclipse.jdt.core.compiler.batch" version="0.0.0"/>
            <unit id="org.eclipse.jdt.apt.core" version="0.0.0"/>
            <unit id="org.eclipse.jdt.launching" version="0.0.0"/>

            <!-- Sprint 11 Phase E: JDT LTK refactoring API
                 (move_class, move_package, pull_up, push_down, encapsulate_field). -->
            <unit id="org.eclipse.jdt.core.manipulation" version="0.0.0"/>
            <unit id="org.eclipse.ltk.core.refactoring" version="0.0.0"/>

            <!-- Eclipse Platform Core -->
            <unit id="org.eclipse.core.runtime" version="0.0.0"/>
            <unit id="org.eclipse.core.resources" version="0.0.0"/>
            <unit id="org.eclipse.core.filesystem" version="0.0.0"/>
            <unit id="org.eclipse.core.jobs" version="0.0.0"/>
            <unit id="org.eclipse.core.contenttype" version="0.0.0"/>
            <unit id="org.eclipse.core.expressions" version="0.0.0"/>

            <!-- OSGi Framework -->
            <unit id="org.eclipse.osgi" version="0.0.0"/>
            <unit id="org.eclipse.osgi.services" version="0.0.0"/>
            <unit id="org.eclipse.osgi.util" version="0.0.0"/>

            <!-- Eclipse Text Framework -->
            <unit id="org.eclipse.text" version="0.0.0"/>
            <unit id="org.eclipse.jface.text" version="0.0.0"/>

            <!-- Equinox for standalone runtime -->
            <unit id="org.eclipse.equinox.common" version="0.0.0"/>
            <unit id="org.eclipse.equinox.preferences" version="0.0.0"/>
            <unit id="org.eclipse.equinox.registry" version="0.0.0"/>
            <unit id="org.eclipse.equinox.app" version="0.0.0"/>

            <!-- Felix SCR - Declarative Services (required by JDT.LS for service management) -->
            <unit id="org.apache.felix.scr" version="0.0.0"/>

            <!-- Debug core (required by JDT launching) -->
            <unit id="org.eclipse.debug.core" version="0.0.0"/>

            <!-- Sprint 12 (v1.6.0): JUnit launching for run_tests.
                 - jdt.junit.core: test discovery + launch config types + the
                   public TestRunListener / ITestCaseElement model API.
                 - jdt.junit.runtime: runner shim for the forked JVM (JUnit 4
                   + the platform-launcher bridge).
                 - jdt.junit5.runtime: Jupiter-engine runner shim. -->
            <unit id="org.eclipse.jdt.junit.core" version="0.0.0"/>
            <unit id="org.eclipse.jdt.junit.runtime" version="0.0.0"/>
            <unit id="org.eclipse.jdt.junit5.runtime" version="0.0.0"/>

            <!-- Executable launcher feature for product -->
            <unit id="org.eclipse.equinox.executable.feature.group" version="0.0.0"/>
        </location>

        <!-- M2E for Maven project support -->
        <location includeAllPlatforms="false" includeConfigurePhase="true" includeMode="planner" includeSource="true" type="InstallableUnit">
            <repository location="${system_property:p2.base}/technology/m2e/releases/latest/"/>
            <unit id="org.eclipse.m2e.core" version="0.0.0"/>
            <unit id="org.eclipse.m2e.jdt" version="0.0.0"/>
            <unit id="org.eclipse.m2e.maven.runtime" version="0.0.0"/>
        </location>

        <!-- Gson - JSON serialization (auto-wrapped as OSGi bundle).
             22c 2026-07-11: BUMPED 2.10.1 -> 2.14.0 (current stable, same minor line). -->
        <location includeDependencyDepth="none" includeSource="true" missingManifest="generate" type="Maven">
            <dependencies>
                <dependency>
                    <groupId>com.google.code.gson</groupId>
                    <artifactId>gson</artifactId>
                    <version>2.14.0</version>
                </dependency>
            </dependencies>
        </location>

        <!-- Jackson - JSON processing (auto-wrapped as OSGi bundle).
             22c 2026-07-11: BUMPED 2.16.1 -> 2.19.0 (current stable, same minor line). -->
        <location includeDependencyDepth="direct" includeSource="true" missingManifest="generate" type="Maven">
            <dependencies>
                <dependency>
                    <groupId>com.fasterxml.jackson.core</groupId>
                    <artifactId>jackson-databind</artifactId>
                    <version>2.19.0</version>
                </dependency>
            </dependencies>
        </location>

        <!-- SLF4J Logging.
             22c 2026-07-11: BUMPED 2.0.9 -> 2.0.18 (current stable patch line;
             2.1.0-alpha1 exists but is not stable — rejected). -->
        <location includeDependencyDepth="none" includeSource="true" missingManifest="generate" type="Maven">
            <dependencies>
                <dependency>
                    <groupId>org.slf4j</groupId>
                    <artifactId>slf4j-api</artifactId>
                    <version>2.0.18</version>
                </dependency>
                <dependency>
                    <groupId>org.slf4j</groupId>
                    <artifactId>slf4j-simple</artifactId>
                    <version>2.0.18</version>
                </dependency>
            </dependencies>
        </location>

        <!-- Sprint 21 (v2.0): H2 embedded DB — the local experience/knowledge store.
             Ships its own OSGi manifest (Bundle-SymbolicName: com.h2database); the
             missingManifest="generate" is a harmless safety net.
             22c 2026-07-11: KEPT at 2.2.224 (2.3.232 is current) — the user-shared
             AUTO_SERVER store is concurrently opened by deployed residents still on
             2.2.224; mixed H2 versions on one live store are a real corruption/protocol
             risk. Bump in a dedicated release once the whole fleet moves together. -->
        <location includeDependencyDepth="none" includeSource="true" missingManifest="generate" type="Maven">
            <dependencies>
                <dependency>
                    <groupId>com.h2database</groupId>
                    <artifactId>h2</artifactId>
                    <version>2.2.224</version>
                </dependency>
            </dependencies>
        </location>

        <!-- JUnit 5 pinned to Eclipse 2024-09 (22c decision, 2026-07-11): trains from
             2025-12 on ship JUnit 6, which Tycho 5.0.x's junit5 surefire provider cannot
             run (requires junit-jupiter [5.0.0,6.0.0)) — same split upstream chose for
             its 2025-12 upgrade. JDT comes from 2026-06 above; JUnit is independent of
             the JDT version. Revisit with the Sprint-23 test-runner work. -->
        <location includeAllPlatforms="false" includeConfigurePhase="true" includeMode="planner" includeSource="true" type="InstallableUnit">
            <repository location="${system_property:p2.base}/releases/2024-09"/>
            <unit id="junit-jupiter-api" version="0.0.0"/>
            <unit id="junit-jupiter-engine" version="0.0.0"/>
            <unit id="junit-jupiter-params" version="0.0.0"/>
            <unit id="junit-platform-commons" version="0.0.0"/>
            <unit id="junit-platform-engine" version="0.0.0"/>
            <unit id="junit-platform-launcher" version="0.0.0"/>
            <unit id="junit-platform-suite-api" version="0.0.0"/>
            <unit id="junit-platform-suite-commons" version="0.0.0"/>
            <unit id="junit-platform-suite-engine" version="0.0.0"/>
            <unit id="org.opentest4j" version="0.0.0"/>
            <unit id="org.apiguardian.api" version="0.0.0"/>
        </location>
    </locations>
</target>
